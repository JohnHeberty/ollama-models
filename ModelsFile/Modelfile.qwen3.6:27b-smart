# --- Parâmetros de Contexto e Memória ---
# 128k de contexto (128 * 1024)
PARAMETER num_ctx 51200
# Limita o número de threads (mantenha 8 ou ajuste conforme seu CPU)
PARAMETER num_thread 7

# --- Parâmetros de Amostragem (Sampling) ---
# min_p ajuda a filtrar tokens de baixa probabilidade sem "cortar" a criatividade
PARAMETER min_p 0.02
# Temperatura levemente baixa para manter a precisão no código
PARAMETER temperature 0.2
# Ajuda o modelo a selecionar apenas os tokens mais prováveis
PARAMETER top_p 0.8
# Penalidade de repetição para evitar loops em contextos longos
PARAMETER repeat_penalty 1.1

# 3. Mensagem de Sistema
